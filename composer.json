{
    "name": "oire/iridium",
    "description": "Iridium, a security library for hashing passwords, encrypting data and managing secure tokens.",
    "type": "library",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/Oire/php-code-style"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-sodium": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "*",
        "oire/php-code-style": "dev-master",
        "phpunit/phpunit": "*",
        "psalm/plugin-phpunit": "*",
        "vimeo/psalm": "dev-master"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for PdoTokenStorage with MySQL/MariaDB"
    },
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "André Polykanine",
            "email": "ap@oire.me",
            "homepage": "https://oire.org/",
            "role": "developer"
        }
    ],
    "support": {
        "issues":   "https://github.com/Oire/Iridium-php/issues",
        "source":   "https://github.com/Oire/Iridium-php"
    },
    "autoload": {
        "psr-4": {
            "Oire\\Iridium\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oire\\Iridium\\Tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/Oire"
        },
        {
            "type": "Ko-fi",
            "url": "https://ko-fi.com/oire"
        },
        {
            "type": "paypal",
            "url": "https://www.paypal.com/donate/?hosted_button_id=D9GB6MGF8BHH8"
        }
    ]
}
